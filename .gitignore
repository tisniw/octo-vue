# ============================================================
# OctoVue Monorepo - Git Ignore Rules
# ============================================================

# ---------- Assets / Docs ----------
# 本地资源 & 文档目录（不参与版本控制）
/assets/

# ---------- Dependencies ----------
# Lockfile is intentionally tracked (yarn.lock)
# All node_modules under any package
**/node_modules/
/node_modules/

# ---------- Build output ----------
dist/
build/
out/
*.tsbuildinfo
.vue-tsbuildinfo

# ---------- Bundler / Build cache ----------
.vite/
.vite-temp/
.turbo/
.cache/
.parcel-cache/
.eslintcache
.stylelintcache

# ---------- Test / Coverage ----------
coverage/
.nyc_output/
test-results/
playwright-report/
playwright/.cache/

# ---------- Logs ----------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---------- Environment ----------
.env
.env.local
.env.*.local

# ---------- IDE / Editor ----------
# JetBrains
.idea/
# .zcode (local workspace helper)
.zcode/
# VSCode (keep extension & workspace settings under version)
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# ---------- OS generated ----------
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# ---------- Misc / Local ----------
*.local
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
