{
  "name": "octovue-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "OctoVue monorepo：基于 Vue 3 的组件库与演示应用",
  "workspaces": {
    "packages": [
      "packages/base/*",
      "packages/infra/*",
      "apps/*"
    ]
  },
  "scripts": {
    "dev": "yarn workspace @octovue/demo dev",
    "build": "yarn workspaces foreach -A -t run build",
    "typecheck": "yarn workspaces foreach -A -t run typecheck",
    "clean": "rimraf node_modules packages/*/node_modules apps/*/node_modules",
    "clean:dist": "rimraf packages/*/dist apps/*/dist"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "rimraf": "^6.1.3",
    "sass-embedded": "^1.83.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vue": "^3.5.39",
    "vue-tsc": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
