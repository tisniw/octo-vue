{
  "name": "@octovue/act",
  "version": "0.1.0",
  "description": "OctoVue Act · 动画编排核心（基于第三方引擎默认 GSAP，提供时间线 / 缓动 / 元素动画协议，框架无关）",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "import": "./src/types.ts",
      "default": "./src/types.ts"
    },
    "./engine-core/base": {
      "types": "./src/engine-core/base/index.ts",
      "import": "./src/engine-core/base/index.ts",
      "default": "./src/engine-core/base/index.ts"
    },
    "./engine-core/engines": {
      "types": "./src/engine-core/engines/index.ts",
      "import": "./src/engine-core/engines/index.ts",
      "default": "./src/engine-core/engines/index.ts"
    },
    "./engine-core/platform": {
      "types": "./src/engine-core/platform/index.ts",
      "import": "./src/engine-core/platform/index.ts",
      "default": "./src/engine-core/platform/index.ts"
    },
    "./engine-core/adapter": {
      "types": "./src/engine-core/adapter/index.ts",
      "import": "./src/engine-core/adapter/index.ts",
      "default": "./src/engine-core/adapter/index.ts"
    },
    "./timeline": {
      "types": "./src/timeline/index.ts",
      "import": "./src/timeline/index.ts",
      "default": "./src/timeline/index.ts"
    },
    "./easing": {
      "types": "./src/easing/index.ts",
      "import": "./src/easing/index.ts",
      "default": "./src/easing/index.ts"
    },
    "./tween": {
      "types": "./src/tween/index.ts",
      "import": "./src/tween/index.ts",
      "default": "./src/tween/index.ts"
    },
    "./compose": {
      "types": "./src/compose/index.ts",
      "import": "./src/compose/index.ts",
      "default": "./src/compose/index.ts"
    },
    "./composables": {
      "types": "./src/composables/index.ts",
      "import": "./src/composables/index.ts",
      "default": "./src/composables/index.ts"
    },
    "./components": {
      "types": "./src/components/index.ts",
      "import": "./src/components/index.ts",
      "default": "./src/components/index.ts"
    },
    "./init": {
      "types": "./src/init/index.ts",
      "import": "./src/init/index.ts",
      "default": "./src/init/index.ts"
    }
  },
  "files": [
    "src",
    "package.json"
  ],
  "dependencies": {
    "@octovue/storage": "*",
    "@octovue/theme": "*",
    "@octovue/utils": "*",
    "d3-color": "^3.1.0",
    "d3-interpolate": "^3.0.0",
    "gsap": "^3.12.0"
  },
  "devDependencies": {
    "@vue/runtime-core": "^3.4.0",
    "typescript": "^6.0.3",
    "vue": "^3.4.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  }
}
