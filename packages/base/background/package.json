{
  "name": "@octovue/background",
  "version": "0.1.0",
  "description": "OctoVue 背景系统：覆盖 7 大分类的视觉统一、主题联动的背景层",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./core": {
      "types": "./src/core/index.ts",
      "import": "./src/core/index.ts"
    },
    "./manager": {
      "types": "./src/manager/index.ts",
      "import": "./src/manager/index.ts"
    },
    "./preset": {
      "types": "./src/preset/index.ts",
      "import": "./src/preset/index.ts"
    }
  },
  "files": [
    "src",
    "package.json"
  ],
  "dependencies": {
    "@octovue/act": "*",
    "@octovue/storage": "*",
    "@octovue/theme": "*",
    "@octovue/utils": "*"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  }
}
