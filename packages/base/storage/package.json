{
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./db": {
      "types": "./src/db/index.ts",
      "import": "./src/db/index.ts",
      "default": "./src/db/index.ts"
    },
    "./cache": {
      "types": "./src/cache/index.ts",
      "import": "./src/cache/index.ts",
      "default": "./src/cache/index.ts"
    },
    "./store": {
      "types": "./src/store/index.ts",
      "import": "./src/store/index.ts",
      "default": "./src/store/index.ts"
    },
    "./asset": {
      "types": "./src/asset/index.ts",
      "import": "./src/asset/index.ts",
      "default": "./src/asset/index.ts"
    },
    "./shared": {
      "types": "./src/shared/index.ts",
      "import": "./src/shared/index.ts",
      "default": "./src/shared/index.ts"
    },
    "./package.json": "./package.json"
  },
  "files": ["src"],
  "name": "@octovue/storage",
  "description": "数据存储层:Pinia 状态管理、本地数据库、文件资产、内存缓存)",
  "sideEffects": false,
  "peerDependencies": {
    "pinia": "^3.0.4",
    "vue": "^3.5.39"
  },
  "peerDependenciesMeta": {
    "pinia": { "optional": true },
    "vue": { "optional": true }
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  }
}
