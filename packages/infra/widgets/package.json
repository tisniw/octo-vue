{
  "name": "@octovue/widgets",
  "version": "0.1.0",
  "description": "Vue 3 UI 组件库（widget 占位目录，按 design 文档长期将由 kits/core 取代）",
  "private": true,
  "type": "module",
  "sideEffects": [
    "./src/**/*.scss",
    "./src/**/*.css"
  ],
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./ui": {
      "types": "./src/ui/index.ts",
      "import": "./src/ui/index.ts"
    },
    "./ui/base": {
      "types": "./src/ui/base/index.ts",
      "import": "./src/ui/base/index.ts"
    },
    "./ui/base/text/index.vue": {
      "import": "./src/ui/base/text/index.vue"
    },
    "./ui/base/text/cpns/*": {
      "import": "./src/ui/base/text/cpns/*"
    },
    "./style.css": "./src/ui/base/text/cpns/index.scss"
  },
  "files": [
    "src",
    "package.json"
  ],
  "peerDependencies": {
    "vue": "^3.5.39"
  },
  "dependencies": {
    "@octovue/theme": "*",
    "@octovue/icon": "*"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}